{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users with access control",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "accessType": { "enum": ["Administrador", "Coordenação", "Profissional", "Recepção"] },
        "status": { "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "accessType", "status"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient medical record information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "medicalRecordNumber": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "enum": ["M", "F", "Outro"] },
        "city": { "type": "string" },
        "diagnoses": { "type": "array", "items": { "type": "string" } },
        "professionals": { "type": "array", "items": { "type": "string" } },
        "status": { "enum": ["Ativo", "Alta", "Investigação", "Espera"] },
        "entryDate": { "type": "string", "format": "date" },
        "dischargeDate": { "type": "string", "format": "date" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "absenteeismCount": { "type": "integer", "default": 0 }
      },
      "required": ["id", "name", "medicalRecordNumber", "status"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Records of patient movements and attendances",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "medicalRecordNumber": { "type": "string" },
        "diagnoses": { "type": "array", "items": { "type": "string" } },
        "professionals": { "type": "array", "items": { "type": "string" } },
        "responsibleProfessional": { "type": "string" },
        "type": { "enum": ["Entrada", "Alta", "Transferência", "Mudança de profissional", "Atualização cadastral", "Atendimento", "Absenteísmo"] },
        "date": { "type": "string", "format": "date-time" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "type", "date"]
    },
    "Professional": {
      "title": "Professional",
      "description": "Multidisciplinary team members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "status": { "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "area", "status"]
    },
    "Sector": {
      "title": "Sector",
      "description": "Clinic sectors/departments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "active"]
    },
    "Municipality": {
      "title": "Municipality",
      "description": "Registered municipalities",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "Patient diagnoses options",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "enum": ["Active", "Inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status"]
    },
    "Form": {
      "title": "Form",
      "description": "NPS satisfaction forms submitted by patients or imported from physical entries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "npsScore": { "type": "integer" },
        "generalComment": { "type": "string" },
        "source": { "enum": ["patient", "physical"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "npsScore", "source", "createdAt"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Granular sector-by-sector smiles satisfaction feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "formId": { "type": "string" },
        "sector": { "type": "string" },
        "rating": { "enum": ["Otimo", "Bom", "Regular", "Ruim"] },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "formId", "sector", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "/pacientes/{patientId}": {
      "schema": "Patient",
      "description": "Collection of patients"
    },
    "/movimentacoes/{movementId}": {
      "schema": "Movement",
      "description": "Collection of patient movements"
    },
    "/profissionais/{professionalId}": {
      "schema": "Professional",
      "description": "Collection of multidisciplinary professionals"
    },
    "/sectors/{sectorId}": {
      "schema": "Sector",
      "description": "Collection of clinics' sectors"
    },
    "/municipios/{municipalityId}": {
      "schema": "Municipality",
      "description": "Collection of municipalities"
    },
    "/diagnosticos/{diagnosisId}": {
      "schema": "Diagnosis",
      "description": "Collection of diagnosis options"
    },
    "/forms/{formId}": {
      "schema": "Form",
      "description": "NPS Forms"
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Specific sector satisfaction evaluations"
    }
  }
}
