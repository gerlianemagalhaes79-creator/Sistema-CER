rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if user has active account in 'usuarios'
    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gerlianemagalhaes79@gmail.com' ||
        request.auth.token.email == 'cer2polisobral@gmail.com' ||
        (hasUserDoc() && getUserData().accessType == 'Administrador')
      );
    }

    function isCoordination() {
      return isSignedIn() && hasUserDoc() && getUserData().accessType == 'Coordenação';
    }

    function isReception() {
      return isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção';
    }

    // Permissive team access to general workspace operations
    function isApprovedUser() {
      return isSignedIn() && (
        isAdmin() || 
        isCoordination() || 
        hasUserDoc()
      );
    }

    // Usuarios collection
    match /usuarios/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        resource.data.email == request.auth.token.email || 
        isAdmin() || 
        isCoordination()
      );
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.email == request.auth.token.email) ||
        (resource == null && request.resource.data.email == request.auth.token.email) ||
        isAdmin()
      );
    }

    // Pacientes collection
    match /pacientes/{patientId} {
      allow read: if isApprovedUser();
      allow write: if isApprovedUser();
    }

    // Movimentacoes collection
    match /movimentacoes/{movementId} {
      allow read: if isApprovedUser();
      allow write: if isApprovedUser();
    }

    // Profissionais collection
    match /profissionais/{professionalId} {
      allow read: if true;
      allow write: if isApprovedUser();
    }

    // Sectors collection
    match /sectors/{sectorId} {
      allow read: if true;
      allow write: if isApprovedUser();
    }

    // Profiles collection for team management
    match /profiles/{profileId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        (resource == null && request.resource.data.email.lower() == request.auth.token.email.lower()) ||
        (resource != null && resource.data.email.lower() == request.auth.token.email.lower()) ||
        (profileId == request.auth.uid) ||
        isApprovedUser()
      );
    }

    // Municipios collection
    match /municipios/{municipalityId} {
      allow read: if isSignedIn();
      allow write: if isApprovedUser();
    }

    // Diagnosticos collection
    match /diagnosticos/{diagnosisId} {
      allow read: if isSignedIn();
      allow write: if isApprovedUser();
    }

    // Forms collection
    match /forms/{formId} {
      allow create: if true;
      allow read: if isSignedIn() && isApprovedUser();
      allow update, delete: if isApprovedUser();
    }

    // Evaluations collection
    match /evaluations/{evaluationId} {
      allow create: if true;
      allow read: if isSignedIn() && isApprovedUser();
      allow update, delete: if isApprovedUser();
    }
  }
}
