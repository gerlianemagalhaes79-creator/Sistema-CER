rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (hasUserDoc() && getUserData().accessType == 'Administrador') || 
        request.auth.token.email == 'gerlianemagalhaes79@gmail.com' ||
        request.auth.token.email == 'cer2polisobral@gmail.com'
      );
    }

    function isCoordination() {
      return isSignedIn() && hasUserDoc() && getUserData().accessType == 'Coordenação';
    }

    function isReception() {
      return isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção';
    }

    // Usuarios collection
    match /usuarios/{userId} {
      allow read: if isSignedIn() && (isAdmin() || isCoordination() || request.auth.uid == userId);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Pacientes collection
    match /pacientes/{patientId} {
      allow read: if isSignedIn() && (
        isAdmin() || isCoordination() || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção') || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Profissional' && resource.data.professionals.hasAny([getUserData().name]))
      );
      allow write: if isAdmin() || isCoordination() || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção') || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Profissional');
    }

    // Movimentacoes collection
    match /movimentacoes/{movementId} {
      allow read: if isSignedIn() && (
        isAdmin() || isCoordination() || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção') || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Profissional' && resource.data.professionals.hasAny([getUserData().name]))
      );
      allow write: if isAdmin() || isCoordination() || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Recepção') || 
        (isSignedIn() && hasUserDoc() && getUserData().accessType == 'Profissional');
    }

    // Profissionais collection
    match /profissionais/{professionalId} {
      allow read: if true;
      allow write: if isAdmin() || isCoordination() || isReception();
    }

    // Sectors collection
    match /sectors/{sectorId} {
      allow read: if true;
      allow write: if isAdmin() || isCoordination() || isReception();
    }

    // Profiles collection for team management
    match /profiles/{profileId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Municipios collection
    match /municipios/{municipalityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoordination() || isReception();
    }

    // Diagnosticos collection
    match /diagnosticos/{diagnosisId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoordination() || isReception();
    }

    // Forms collection
    match /forms/{formId} {
      allow create: if true;
      allow read: if isSignedIn() && (isAdmin() || isCoordination() || (isSignedIn() && hasUserDoc() && (getUserData().accessType == 'Profissional' || getUserData().accessType == 'Recepção')));
      allow update, delete: if isAdmin() || isCoordination();
    }

    // Evaluations collection
    match /evaluations/{evaluationId} {
      allow create: if true;
      allow read: if isSignedIn() && (isAdmin() || isCoordination() || (isSignedIn() && hasUserDoc() && (getUserData().accessType == 'Profissional' || getUserData().accessType == 'Recepção')));
      allow update, delete: if isAdmin() || isCoordination();
    }
  }
}
